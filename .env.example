# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — OBRIGATÓRIO para gravar dados (Project Settings → API)
# Sem estas variáveis o app BLOQUEIA cadastros para não perder informação.
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Opcional — só se usar e-mail custom / redirects
# SUPABASE_JWT_SECRET=
